{
  "name": "langgraph-mcp",
  "version": "1.0.0",
  "description": "MCP server bridging Archie (laptop) to AppFactory (VM) — LangGraph, Langfuse, and Qdrant tools",
  "type": "module",
  "scripts": {
    "dev": "node --env-file=.env --import=tsx/esm src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "node --import=tsx/esm --test src/**/*.test.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@qdrant/js-client-rest": "^1.9.0",
    "dotenv": "^16.4.0",
    "openai": "^4.52.0",
    "zod": "^3.23.0",
    "zod-to-json-schema": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  }
}
